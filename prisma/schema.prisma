datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Card {
  id          String   @id @default(cuid())
  userId      String
  boardId     String
  boardColumnId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?  @db.Text
  image       String?
  name        String?
  members     Json?    @db.Json
  tags        Json?    @db.Json
  position    Int
  user        User?    @relation(fields: [userId], references: [id])
  board       Board?   @relation(fields: [boardId], references: [id])
  boardColumn BoardColumn? @relation(fields: [boardColumnId], references: [id])

  @@map("cards")
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  name      String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  board     Board?   @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@map("board_columns")
}

model Board {
  id          String   @id @default(cuid())
  userId      String
  projectId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?  @db.Text
  imageUrl    String?
  imageName   String?
  name        String
  members     Json?    @db.Json
  favorite    Boolean  @default(false)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user        User?    @relation(fields: [userId], references: [id])

  cards Card[]
  boardColumns BoardColumn[]
  userFavorites UserBoardFavorites[]
  userIsMember UserBoardIsMember[]

  @@map("boards")
}

model UserBoardIsMember {
  id        String   @id @default(cuid())
  userId    String
  boardId   String
  role      users_roles
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  board     Board?   @relation(fields: [boardId], references: [id])

  @@unique([userId, boardId])
  @@map("user_board_is_member")
}

model UserBoardFavorites {
  id        String   @id @default(cuid())
  userId    String
  boardId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  board     Board?   @relation(fields: [boardId], references: [id])

  @@unique([userId, boardId])
  @@map("user_board_favorites")
  
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?  @db.Text
  name        String
  members     Json?    @db.Json
  favorite    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id])

  boards Board[]
  userFavorites UserProjectFavorites[]
  userIsMember UserProjectIsMember[]

  @@map("projects")
}

model UserProjectIsMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      users_roles
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@map("user_project_is_member")
}

model UserProjectFavorites {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
  @@map("user_project_favorites")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String
  username      String?
  roles         users_roles?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  projects Project[]
  boards   Board[]
  cards    Card[]
  accounts Account[]
  sessions Session[]
  userBoardFavorites UserBoardFavorites[]
  userProjectFavorites UserProjectFavorites[]
  userBoardIsMember UserBoardIsMember[]
  userProjectIsMember UserProjectIsMember[]

  @@map("users")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

enum users_roles {
  ADMIN
  USER
}
